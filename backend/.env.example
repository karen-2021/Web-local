# ── Base de datos ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saaslocal
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────
# Cambia esto por un string random de al menos 32 chars en producción
JWT_SECRET=supersecreto_cambia_en_produccion_XYZ987
JWT_EXPIRES=8h

# ── Servidor ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
