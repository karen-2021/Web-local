# ============================================================
# SaasLocal — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# ── Base de datos ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saaslocal
DB_USER=postgres
DB_PASSWORD=postgres_seguro_aqui
DB_POOL_MAX=20
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_STRING_ALEATORIO_DE_AL_MENOS_48_CHARS
JWT_EXPIRES=8h

# ── Servidor ───────────────────────────────────────────────
PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# ── CORS (URL del frontend) ────────────────────────────────
# En producción: tu dominio real, ej: https://mitienda.com
CORS_ORIGIN=http://localhost

# ── Docker / App ───────────────────────────────────────────
APP_PORT=80          # Puerto externo del contenedor frontend

# ── Frontend (Vite) ────────────────────────────────────────
# Solo necesario al hacer build fuera de Docker
VITE_API_URL=/api/v1
